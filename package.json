{
	"name": "michael-distel-website",
	"version": "1.0.0",
	"description": "Personal website and digital garden exploring startups, Web3 infrastructure, and industrial automation",
	"author": "Michael Distel <michael@distel.me>",
	"homepage": "https://michaeldistel.com",
	"repository": {
		"type": "git",
		"url": "git+https://github.com/michaeldistel/michael-distel-website.git"
	},
	"bugs": {
		"url": "https://github.com/michaeldistel/michael-distel-website/issues"
	},
	"keywords": [
		"sveltekit",
		"personal-website",
		"digital-garden",
		"startup-notes",
		"web3",
		"industrial-automation"
	],
	"private": true,
	"scripts": {
		"dev": "vite dev",
		"build": "vite build",
		"preview": "vite preview",
		"check": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
		"check:watch": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json --watch",
		"lint": "prettier --check .",
		"format": "prettier --write .",
		"cf:deploy": "pnpm prod:build && cf pages deploy build --project-name=michaeldistel-website --branch=main --commit-dirty=true",
		"prod:build": "pnpm prebuild && pnpm build",
		"prebuild": "node scripts/generate-build-info.cjs",
		"postinstall": "node scripts/generate-build-info.cjs"
	},
	"devDependencies": {
		"@sveltejs/adapter-auto": "^6.1.0",
		"@sveltejs/adapter-static": "^3.0.9",
		"@sveltejs/kit": "^2.36.1",
		"@sveltejs/vite-plugin-svelte": "^6.1.3",
		"@tailwindcss/postcss": "^4.2.1",
		"autoprefixer": "^10.4.21",
		"postcss": "^8.5.6",
		"prettier": "^3.6.2",
		"prettier-plugin-svelte": "^3.4.0",
		"svelte": "^5.38.2",
		"svelte-check": "^4.3.1",
		"tailwindcss": "^4.2.1",
		"tslib": "^2.8.1",
		"typescript": "^5.9.2",
		"vite": "^7.1.3"
	},
	"type": "module",
	"dependencies": {
		"chart.js": "^4.5.0",
		"chartjs-adapter-date-fns": "^3.0.0",
		"date-fns": "^4.1.0"
	}
}
